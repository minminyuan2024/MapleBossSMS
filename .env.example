# Twilio (SMS) — https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
# Or use a single From number (E.164) if you are not using Messaging Service:
# TWILIO_FROM_NUMBER=+15551234567

# Protect cron / bulk SMS endpoint (set a long random string)
CRON_SECRET=

# Optional: base URL for links in SMS (e.g. https://your-domain.com)
PUBLIC_APP_URL=http://localhost:3000
